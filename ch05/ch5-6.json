        "responseBody": "=<!DOCTYPE html>\n<html lang=\"zh-TW\">\n<head><meta charset=\"UTF-8\"><title>OCR 完成</title>\n<style>\n  body{font-family:Arial,sans-serif;max-width:520px;margin:60px auto;background:#e8f8f8;}\n  .card{background:white;padding:32px;border-radius:10px;box-shadow:0 2px 12px rgba(0,0,0,0.12);}\n  h2{color:#0E6B6B;} table{width:100%;border-collapse:collapse;margin:16px 0;}\n  td,th{padding:9px 12px;border:1px solid #ddd;font-size:14px;}\n  th{background:#0E6B6B;color:white;text-align:left;}\n  tr:nth-child(even){background:#EBF9F9;}\n  .ok{color:green;font-weight:bold;font-size:16px;}\n  a{display:block;margin-top:18px;text-align:center;color:#0E6B6B;}\n</style>\n</head>\n<body>\n<div class=\"card\">\n  <h2>✅ LLM-OCR 識別完成</h2>\n  <p class=\"ok\">已成功識別並存入記錄！</p>\n  <table>\n    <tr><th>欄位</th><th>識別結果</th></tr>\n    <tr><td>記錄編號</td><td>{{ $json.data['記錄編號'] }}</td></tr>\n    <tr><td>發票號碼</td><td>{{ $json.data['發票號碼'] }}</td></tr>\n    <tr><td>發票日期</td><td>{{ $json.data['發票日期'] }}</td></tr>\n    <tr><td>賣方名稱</td><td>{{ $json.data['賣方名稱'] }}</td></tr>\n    <tr><td>買方名稱</td><td>{{ $json.data['買方名稱'] }}</td></tr>\n    <tr><td>金額</td><td>NT$ {{ $json.data['金額'] }}</td></tr>\n  </table>\n  <a href=\"/webhook-test/invoice-upload\">← 再上傳一張</a>\n</div>\n</body>\n</html>\n",

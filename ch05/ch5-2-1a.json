      "parameters": {
        "respondWith": "text",
        "responseBody": "<!DOCTYPE html>\n<html lang=\"zh-TW\">\n<head>\n<meta charset=\"UTF-8\">\n<title>商品訂購</title>\n<style>\n  body { font-family: Arial, sans-serif; max-width: 500px; margin: 60px auto; background: #f0f4f8; }\n  .card { background: white; padding: 32px; border-radius: 10px; box-shadow: 0 2px 12px rgba(0,0,0,0.1); }\n  h2 { color: #1E4B8E; margin-bottom: 24px; }\n  label { display: block; font-weight: bold; margin: 12px 0 4px; color: #333; }\n  input, select { width: 100%; padding: 9px 12px; border: 1px solid #ccc; border-radius: 5px; box-sizing: border-box; font-size: 14px; }\n  button { width: 100%; margin-top: 20px; padding: 12px; background: #1E4B8E; color: white; border: none; border-radius: 5px; font-size: 15px; font-weight: bold; cursor: pointer; }\n  button:hover { background: #2D6A9F; }\n</style>\n</head>\n<body>\n<div class=\"card\">\n  <h2>🛒 商品訂購</h2>\n  <form action=\"/webhook/order-submit\" method=\"POST\">\n    <label>客戶姓名</label>\n    <input name=\"customerName\" required placeholder=\"王小明\">\n    <label>客戶 Email</label>\n    <input name=\"customerEmail\" type=\"email\" required placeholder=\"email@example.com\">\n    <label>商品</label>\n    <select name=\"productId\" required>\n      <option value=\"\">-- 請選擇商品 --</option>\n      <option value=\"P001|藍牙耳機|1200\">藍牙耳機 - NT$1,200</option>\n      <option value=\"P002|無線滑鼠|650\">無線滑鼠 - NT$650</option>\n      <option value=\"P003|機械鍵盤|2800\">機械鍵盤 - NT$2,800</option>\n      <option value=\"P004|USB集線器|380\">USB集線器 - NT$380</option>\n      <option value=\"P005|行動電源|890\">行動電源 - NT$890</option>\n    </select>\n    <label>數量</label>\n    <input name=\"quantity\" type=\"number\" min=\"1\" max=\"99\" value=\"1\" required>\n    <label>出貨日期</label>\n    <input name=\"shipDate\" type=\"date\" required>\n    <button type=\"submit\">送出訂單</button>\n  </form>\n</div>\n</body>\n</html>",
        "options": {}

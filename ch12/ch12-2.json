        "jsonBody": "={\n  \"replyToken\": \"{{ $('Code - 解析LINE事件').item.json.replyToken }}\",\n  \"messages\": [\n    {\n      \"type\": \"text\",\n      \"text\": \"👋 歡迎使用智能客服系統！\\n\\n我是AI助理，可以幫您：\\n✓ 產品諮詢\\n✓ 訂單查詢\\n✓ 常見問題解答\\n✓ 技術支援\\n\\n請直接輸入您的問題，我會盡快為您服務！\"\n    }\n  ]\n}",
        "options": {}

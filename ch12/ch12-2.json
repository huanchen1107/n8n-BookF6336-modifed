    {
      "parameters": {
        "jsCode": "// 組合用戶上下文，提供給 OpenAI 使用\nconst currentMessage = $('Code - 解析LINE事件').first().json;\nconst userProfile = $input.first().json;\n\nconst context = {\n  userId: currentMessage.userId,\n  replyToken: currentMessage.replyToken,\n  currentQuestion: currentMessage.messageText,\n  userName: userProfile?.['用戶名稱'] || '訪客',\n  previousIssues: userProfile?.['歷史問題'] || '無',\n  interactionCount: Number(userProfile?.['互動次數'] || 0),\n  lastInteraction: userProfile?.['上次互動時間'] || '首次互動',\n  satisfactionScore: userProfile?.['滿意度'] || 'N/A',\n  isNewUser: !userProfile?.['LINE用戶ID'], \n  rowNumber: Number(userProfile?.['_rowNumber'] || 0)\n};\n\nreturn [{ json: context }];"
      },
      "id": "eadd70d9-4cf6-4e3c-906e-8519372d5245",
      "name": "Code - 組合用戶上下文",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        496,
        -32
      ]
    },
    {
      "parameters": {
        "jsCode": "// 將 FAQ 資料庫轉為純文字，方便放入 OpenAI Prompt\nconst faqs = $input.all();\n\nif (faqs.length === 0 || !faqs[0].json['問題']) {\n  return [{ json: { faqKnowledge: '（知識庫目前為空，請稍後）' } }];\n}\n\nconst faqText = faqs\n  .filter(item => item.json['問題'] && item.json['答案'])\n  .map((item, index) => {\n    const cat = item.json['分類'] ? ` [${item.json['分類']}]` : '';\n    return `Q${index + 1}${cat}: ${item.json['問題']}\\nA: ${item.json['答案']}`;\n  })\n  .join('\\n\\n');\n\nreturn [{ json: { faqKnowledge: faqText } }];"
      },
      "id": "483ee71e-c1a5-446e-a578-1c3b3639fbf7",
      "name": "Code - 轉換FAQ為文字",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        880,
        -240
      ]
    },
    {
      "parameters": {
        "jsCode": "// 解析 OpenAI 回傳的 JSON 字串\nconst items = $input.all();\nconst results = [];\n\nfor (const item of items) {\n  try {\n    const raw = item.json.output?.[0]?.content?.[0]?.text \n         || item.json.message?.content \n         || item.json.content \n         || item.json.text \n         || '';\n    const cleaned = raw.replace(/```json\\n?/g, '').replace(/```\\n?/g, '').trim();\n    const parsed = JSON.parse(cleaned);\n    \n    // 判斷是否需要人工：needHuman=true 或 confidence=低 或 answer=NEED_HUMAN\n    const needHuman = parsed.needHuman === true\n      || parsed.confidence === '低';\n    \n    results.push({\n      json: {\n        answer: parsed.answer || '',\n        needHuman: needHuman,\n        category: parsed.category || '未分類',\n        confidence: parsed.confidence || '低'\n      }\n    });\n  } catch (e) {\n    results.push({\n      json: {\n        answer: 'NEED_HUMAN',\n        needHuman: true,\n        category: '解析錯誤',\n        confidence: '低',\n        _error: e.message\n      }\n    });\n  }\n}\n\nreturn results;"
      },
